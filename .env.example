# ── Kafka / Redpanda ───────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_TOPIC=livreurs-gps
ORDER_OFFERS_TOPIC=order-offers-v1
ORDER_EVENTS_TOPIC=order-events-v1
CONTEXT_SIGNALS_TOPIC=context-signals-v1

# Driver ingest gateway (real courier devices -> Kafka livreurs-gps)
# For production, rotate this token and prefer DRIVER_INGEST_TOKENS_JSON.
DRIVER_INGEST_TOKEN=dev-insecure-token
# Example advanced scope map:
# DRIVER_INGEST_TOKENS_JSON={"token_l001":"L001","ops_token":"*"}
DRIVER_INGEST_RATE_LIMIT_PER_MIN=1800
DRIVER_INGEST_MAX_BATCH_SIZE=200
DRIVER_INGEST_COMPRESSION=gzip


# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
GPS_TTL_SECONDS=30

# ── Cold Path ──────────────────────────────────────────────────────────────────
BATCH_INTERVAL_SECONDS=60     # Flush Parquet toutes les 60 secondes
MAX_BATCH_RECORDS=50000       # Ou si le buffer dépasse 50 000 lignes
DATA_PATH=/data/parquet
EVENTS_PATH=/data/parquet_events

# Copilot Features
COPILOT_OFFER_TTL_SECONDS=21600
COPILOT_MAX_OFFERS_PER_DRIVER=100
FUEL_COST_EUR_PER_KM=0.35
COPILOT_MODEL_MIN_ROWS=300
COPILOT_MODEL_MIN_AUC=0.62
COPILOT_MODEL_MIN_AVG_PRECISION=0.45

# ── NYC TLC HVFHV trip replay (real Uber data) ───────────────────────────────
# Downloads the monthly NYC Taxi & Limousine Commission High Volume For-Hire
# Vehicle parquet (real Uber/Lyft trips) and streams Uber-only trips into the
# order-offers-v1, order-events-v1 AND livreurs-gps topics at the configured
# speed factor. This is the sole source of courier positions / offers / events —
# there is no simulator.
#
# Pick a month that exists at https://www.nyc.gov/site/tlc/about/tlc-trip-record-data.page
# (data is published with ~2 month delay, so use e.g. 2024-01 / 2024-12).
TLC_MONTH=2024-01
TLC_MONTHS=                        # optional CSV list; if set, overrides TLC_MONTH_COUNT
TLC_MONTH_COUNT=0                  # optional consecutive months from TLC_MONTH (10 for 10m, 12 for 1 year)
TLC_BASE_URL=https://d37ci6vzurychx.cloudfront.net/trip-data
TLC_LICENSE_FILTER=HV0003          # HV0003 = Uber, HV0005 = Lyft
TLC_SPEED_FACTOR=1                 # 1 = real time, 6 = 6× faster, …
TLC_TICK_INTERVAL_SEC=5            # emit interpolated positions every N virtual seconds
TLC_TRIP_SAMPLE_RATE=0.15          # deterministic hash sampling → ~500-800 concurrent courses
TLC_MAX_ACTIVE_TRIPS=800           # hard ceiling on concurrent in-flight trips
TLC_LOOP_ON_FINISH=true            # restart from row 0 when the month is fully replayed

# ── Single-driver demo scenario (continuous pseudo-driver) ───────────────────
# Activate by setting TLC_SCENARIO=single_driver. TLC_MONTH is then treated as
# the first month of the TRAIN window (TLC_TRAIN_MONTH_COUNT months), and the
# replay only emits events for the next TLC_LIVE_MONTH_COUNT months (the "live"
# window). Runtime state (replay cursors + Redis keys) is wiped on startup
# when TLC_RESET_RUNTIME_ON_START=true so the demo always restarts clean.
# The model pickle on disk is NOT touched by the runtime reset — the ML
# trainer has its own cache guard based on train-window signature.
TLC_SCENARIO=single_driver         # single_driver (default) ; use fleet for stress/perf only
TLC_SINGLE_DRIVER_ID=drv_demo_001
TLC_TRAIN_MONTH_COUNT=10
TLC_LIVE_MONTH_COUNT=2
TLC_RESET_RUNTIME_ON_START=true
TLC_NIGHT_ACCEL_START=02:00
TLC_NIGHT_ACCEL_END=08:00
TLC_NIGHT_ACCEL_FACTOR=8
TLC_LUNCH_BREAK_ENABLED=true
TLC_LUNCH_BREAK_WINDOW=12:00-14:00
TLC_LUNCH_BREAK_MIN=20
TLC_LUNCH_BREAK_MAX=45

# ── Routing provider chain (used by the single-driver scenario) ─────────────
# Comma-separated, ordered: public routing API first (if key present), then
# local OSRM. When no provider is available the scenario holds the driver at
# its last routed point instead of teleporting — no straight-line fallback.
ROUTING_PROVIDERS=public,osrm_public,osrm
ROUTING_PUBLIC_PROVIDER=openrouteservice
ROUTING_PUBLIC_BASE_URL=https://api.openrouteservice.org
ROUTING_PUBLIC_API_KEY=
ROUTING_OSRM_URL=http://osrm:5000
ROUTING_OSRM_PUBLIC_URL=https://router.project-osrm.org

# ── Context poller (real-time market context via public APIs) ─────────────────
# Streams ContextSignalV1 events for each of the 263 NYC taxi zones by polling:
# - Citi Bike GBFS (station availability → demand_index)
# - Open-Meteo (temperature/precipitation → weather_factor)
# - NYC 311 Socrata (traffic complaints → traffic_factor)
# - Redis GEO (live TLC courier count → supply_index)
CONTEXT_TICK_SECONDS=30
GBFS_POLL_SECONDS=60
WEATHER_POLL_SECONDS=600
NYC311_POLL_SECONDS=300
COURIER_GEO_KEY=fleet:geo
CONTEXT_QUALITY_KEY=copilot:context:quality
CONTEXT_QUALITY_WINDOW_CYCLES=10
CONTEXT_SUPPLY_VARIANCE_EPSILON=0.03
CONTEXT_SUPPLY_FLAT_MIN_CYCLES=6

# ── OpenChargeMap (NYC EV charging stations) ─────────────────────────────────
# Consumed directly by the API for the /copilot/context endpoint.
# Free tier requires a key since 2023: https://openchargemap.org/site/develop/api
OPENCHARGEMAP_API_KEY=

# ── OSRM routing (optional, requires data prep for NY) ───────────────────────
# Run: bash scripts/prepare_osrm.sh new-york
# Then: docker compose --profile routing up osrm
OSRM_URL=http://osrm:5000
