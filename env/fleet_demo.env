# FleetStream — Profil démo flotte multi-chauffeurs (COP-027)
# Mode "jury demo" : 200-300 chauffeurs simultanés, scénario déterministe + seed stable.
# Usage: docker compose --env-file env/fleet_demo.env up -d
#        make fleet-demo-up

TLC_SCENARIO=fleet_demo
TLC_FLEET_DEMO_N_DRIVERS=250
TLC_FLEET_DEMO_SEED=42
TLC_FLEET_DEMO_ZONE_SPREAD=30
TLC_MONTH=2024-01
TLC_TRAIN_MONTH_COUNT=10
TLC_LIVE_MONTH_COUNT=2
TLC_RESET_RUNTIME_ON_START=true

# Débit adapté : flushs plus fréquents pour voir l'activité en demo
BATCH_INTERVAL_SECONDS=15
MAX_BATCH_RECORDS=20000

# GPS TTL réduit pour garder la vue flotte fraîche
GPS_TTL_SECONDS=20

# Warmup: attendre N chauffeurs actifs avant d'ouvrir la démo
FLEET_DEMO_WARMUP_MIN_DRIVERS=50
FLEET_DEMO_WARMUP_TIMEOUT_S=120

# Routing : public-first pour suivre les routes réelles
ROUTING_PROVIDERS=public,osrm_public,osrm
ROUTING_PUBLIC_PROVIDER=openrouteservice
ROUTING_PUBLIC_BASE_URL=https://api.openrouteservice.org
ROUTING_PUBLIC_API_KEY=
ROUTING_OSRM_URL=http://osrm:5000
ROUTING_OSRM_PUBLIC_URL=https://router.project-osrm.org

# Réduction logs pour perf en demo
LOG_LEVEL=WARNING
