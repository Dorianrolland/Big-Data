# FleetStream - Fleet demo profile (COP-033)
# Usage:
#   docker compose --env-file env/fleet_demo.env up -d --build

TLC_SCENARIO=fleet
TLC_FLEET_DEMO_N_DRIVERS=360
TLC_FLEET_DEMO_SEED=42
TLC_FLEET_DEMO_ZONE_SPREAD=30
TLC_MONTH=2024-01
TLC_TRAIN_MONTH_COUNT=10
TLC_LIVE_MONTH_COUNT=2
TLC_RESET_RUNTIME_ON_START=true

# Replay throughput tuning for fast warmup to 200-300 active drivers.
# Higher sampling and active-cap keep demo density realistic on map.
TLC_TRIP_SAMPLE_RATE=0.09
TLC_SPEED_FACTOR=4
TLC_TICK_INTERVAL_SEC=4.0
TLC_MAX_ACTIVE_TRIPS=1400
TLC_INGEST_BATCH_SIZE=3000
TLC_START_HOUR_UTC=11
TLC_COURIER_ID_MODE=trip
TLC_ROUTE_MODE=osrm
TLC_ROUTE_OSRM_FALLBACK_URL=https://router.project-osrm.org
TLC_ROUTE_FETCH_TIMEOUT_S=0.35
TLC_ROUTE_PREFETCH_ENABLED=true
TLC_ROUTE_PREFETCH_MAX_PENDING=128
TLC_ROUTE_PREFETCH_MAX_CONCURRENCY=1
TLC_NIGHT_ACCEL_START=00:00
TLC_NIGHT_ACCEL_END=07:00
TLC_NIGHT_ACCEL_FACTOR=1

# Faster flush for visible activity in demo.
BATCH_INTERVAL_SECONDS=10
MAX_BATCH_RECORDS=25000

# Keep active drivers visible despite ingestion jitter.
GPS_TTL_SECONDS=90

# Warmup target for jury mode.
FLEET_DEMO_WARMUP_MIN_DRIVERS=200
FLEET_DEMO_WARMUP_TIMEOUT_S=240
FLEET_DEMO_REPLAY_GRACE_S=45

# Replay/focus guardrails to reduce cold-path 504 risks.
COPILOT_REPLAY_MAX_RANGE_HOURS=24
COPILOT_REPLAY_MAX_RANGE_NO_DRIVER_HOURS=2
COPILOT_REPLAY_DEFAULT_LIMIT=300
COPILOT_REPLAY_MAX_LIMIT=1500
COPILOT_REPLAY_SOURCE_LIMIT_FACTOR=4
COPILOT_REPLAY_COLUMN_CACHE_TTL_SECONDS=120
COPILOT_REPLAY_COLUMN_CACHE_MAX=512
FOCUS_TRAIL_LOOKBACK_MIN=30
FOCUS_TRAIL_QUERY_TIMEOUT_SECONDS=3.0
STATS_STATUS_SCAN_LIMIT=800
STATS_COLD_CACHE_TTL_SECONDS=90
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
REDIS_OP_TIMEOUT_SECONDS=2.5
COPILOT_DUCKDB_QUERY_TIMEOUT_SECONDS=8.0
DUCKDB_QUERY_TIMEOUT_SECONDS=8.0
ANALYTICS_COLD_QUERY_TIMEOUT_SECONDS=4.0
UVICORN_WORKERS=1

# Routing providers (prefer public fallback for demo continuity).
ROUTING_PROVIDERS=public,osrm_public,osrm
ROUTING_PUBLIC_PROVIDER=openrouteservice
ROUTING_PUBLIC_BASE_URL=https://api.openrouteservice.org
ROUTING_PUBLIC_API_KEY=
ROUTING_OSRM_URL=http://osrm:5000
ROUTING_OSRM_PUBLIC_URL=https://router.project-osrm.org

# Reduce log noise under load.
LOG_LEVEL=WARNING
DASHBOARD_REFRESH_SECONDS=10
DASHBOARD_ANALYTICS_TTL_SECONDS=120
DASHBOARD_ZONE_COVERAGE_TTL_SECONDS=180
