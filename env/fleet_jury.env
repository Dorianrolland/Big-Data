# FleetStream - Jury-safe fleet profile
# Usage:
#   docker compose --env-file env/fleet_jury.env --profile routing up -d --build

TLC_SCENARIO=fleet
TLC_FLEET_DEMO_N_DRIVERS=280
TLC_FLEET_DEMO_SEED=42
TLC_FLEET_DEMO_ZONE_SPREAD=28
TLC_MONTH=2024-01
TLC_TRAIN_MONTH_COUNT=10
TLC_LIVE_MONTH_COUNT=2
TLC_RESET_RUNTIME_ON_START=true

# Safer replay profile for oral demo continuity.
TLC_TRIP_SAMPLE_RATE=0.12
TLC_SPEED_FACTOR=28
TLC_TICK_INTERVAL_SEC=1.25
TLC_ROUTE_DENSIFY_MAX_STEP_KM=0.02
TLC_MAX_ACTIVE_TRIPS=1100
TLC_INGEST_BATCH_SIZE=2500
TLC_START_HOUR_UTC=14
TLC_COURIER_ID_MODE=fleet_pool
TLC_ROUTE_MODE=osrm
TLC_ROUTE_LINEAR_FALLBACK_ALLOWED=false
TLC_ROUTE_SYNC_ON_CACHE_MISS=true
TLC_ROUTE_SYNC_KEY_REPEAT_THRESHOLD=1
TLC_ROUTE_FETCH_TIMEOUT_S=2.5
TLC_ROUTE_WAYPOINT_MAX_SNAP_KM=0.4
TLC_ZONE_ANCHOR_MAX_SNAP_KM=1.2
TLC_ROUTE_FAIL_STREAK_TO_COOLDOWN=8
TLC_ROUTE_FAIL_COOLDOWN_S=45
TLC_ROUTE_PREFETCH_ENABLED=true
TLC_ROUTE_PREFETCH_MAX_PENDING=256
TLC_ROUTE_PREFETCH_MAX_CONCURRENCY=6
TLC_REQUIRE_LOCAL_OSRM_DATA=true
TLC_LOCAL_OSRM_DATA_FILE=/data/osrm/new-york-latest.osrm.properties
TLC_LIVE_ROUTE_MAX_STEP_KM=0.04
TLC_LIVE_ROUTE_MAX_POINTS_PER_TICK=18
TLC_NIGHT_ACCEL_START=00:00
TLC_NIGHT_ACCEL_END=07:00
TLC_NIGHT_ACCEL_FACTOR=1

# Hot path guardrails and recent track.
GPS_TTL_SECONDS=90
FLEET_TRACK_MAX_POINTS=64
FLEET_TRACK_TTL_SECONDS=180
GPS_GUARD_MAX_SPEED_KMH=120
GPS_GUARD_MAX_JUMP_KM=4.0
GPS_GUARD_BACKTRACK_KM=0.8
GPS_GUARD_BACKTRACK_WINDOW_S=90
GPS_GUARD_FROZEN_EPSILON_M=8
GPS_GUARD_FROZEN_STREAK=4

# Faster flush for visible activity in demo.
BATCH_INTERVAL_SECONDS=10
MAX_BATCH_RECORDS=25000

# Warmup target for jury mode.
FLEET_DEMO_WARMUP_MIN_DRIVERS=140
FLEET_DEMO_WARMUP_TIMEOUT_S=600
FLEET_DEMO_REPLAY_GRACE_S=45

# Replay/focus guardrails to reduce cold-path 504 risks.
COPILOT_REPLAY_MAX_RANGE_HOURS=24
COPILOT_REPLAY_MAX_RANGE_NO_DRIVER_HOURS=2
COPILOT_REPLAY_DEFAULT_LIMIT=300
COPILOT_REPLAY_MAX_LIMIT=1500
COPILOT_REPLAY_SOURCE_LIMIT_FACTOR=4
COPILOT_REPLAY_COLUMN_CACHE_TTL_SECONDS=120
COPILOT_REPLAY_COLUMN_CACHE_MAX=512
FOCUS_TRAIL_LOOKBACK_MIN=30
FOCUS_TRAIL_QUERY_TIMEOUT_SECONDS=3.0
STATS_STATUS_SCAN_LIMIT=800
STATS_COLD_CACHE_TTL_SECONDS=90
REDIS_CONNECT_TIMEOUT_SECONDS=2.0
REDIS_OP_TIMEOUT_SECONDS=2.5
COPILOT_DUCKDB_QUERY_TIMEOUT_SECONDS=8.0
DUCKDB_QUERY_TIMEOUT_SECONDS=8.0
ANALYTICS_COLD_QUERY_TIMEOUT_SECONDS=4.0
UVICORN_WORKERS=1

# Routing providers.
ROUTING_PROVIDERS=public,osrm_public,osrm
ROUTING_PUBLIC_PROVIDER=openrouteservice
ROUTING_PUBLIC_BASE_URL=https://api.openrouteservice.org
ROUTING_PUBLIC_API_KEY=
ROUTING_OSRM_URL=http://osrm:5000
ROUTING_OSRM_PUBLIC_URL=https://router.project-osrm.org

# Reduce log noise under load.
LOG_LEVEL=WARNING
DASHBOARD_REFRESH_SECONDS=10
DASHBOARD_ANALYTICS_TTL_SECONDS=120
DASHBOARD_ZONE_COVERAGE_TTL_SECONDS=180
